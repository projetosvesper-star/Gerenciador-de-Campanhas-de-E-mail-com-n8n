# Configuracoes do n8n Local
N8N_HOST=localhost
N8N_PORT=5678
N8N_WEBHOOK_URL=http://localhost:5678/

# Caminho de persistencia de arquivos do n8n
# No Windows, corresponde a pasta mapeada no volume Docker (ex: C:\n8n\files)
N8N_FILES_PATH=/files

# Configuracao SMTP para envio real (Modo Producao)
# NOTA: Na versao demonstrativa (Modo Demo), os disparos sao simulados
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=sender@example.com
SMTP_PASS=sua_senha_secreta_aqui
SMTP_SENDER_EMAIL=sender@example.com
SMTP_SENDER_NAME="SmartMail Demo"
SMTP_SSL=true
